{
  "_help": "Each check re-derives a published number from a committed script. A submission that reports a number adds an entry here: name it, give the exact command (use 'python -m ...' run from the repo root), and list strings from its output that must appear (verbatim, including the number). CI runs ci/reproduce.py on every pull request; a check fails if the command exits non-zero or any expected string is missing. Keep checks fast and deterministic. See PUBLISHING.md.",
  "checks": [
    {
      "name": "instrument-controls",
      "cmd": "python -m org_frontier.classifier.validate",
      "expect": [
        "Instrument validated",
        "ats_triad_mediator     -> triadic",
        "gig_dyadic_model       -> dyadic"
      ],
      "timeout": 180,
      "source": "org_frontier/classifier/FINDINGS.md"
    },
    {
      "name": "parity-determination",
      "cmd": "python -m org_frontier.corpus.determination",
      "expect": [
        "parity functions ['XOR', 'XNOR'] lead: 4/16 each vs 2/16 for monotone"
      ],
      "timeout": 300,
      "source": "org_frontier/STRUCTURAL_FINDINGS.md (finding 4)"
    },
    {
      "name": "q49-h1-seam-tie",
      "cmd": "python -m org_frontier.questions.q49_mip_seam_mincut.probe_seam_tie",
      "expect": [
        "seam set (singleton-severing two-part cuts): ['C', 'W']",
        "H1 VERDICT: CONFIRMED"
      ],
      "timeout": 120,
      "source": "org_frontier/questions/q49_mip_seam_mincut/FINDINGS.md (H1)"
    },
    {
      "name": "q49-h2-seam-family",
      "cmd": "python -m org_frontier.questions.q49_mip_seam_mincut.probe_seam_family",
      "expect": [
